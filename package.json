{
  "name": "baked-with-blessings",
  "version": "1.0.0",
  "description": "Cafe website for Baked with Blessings, based on the Payload ecommerce template",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "bootstrap:admin": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/bootstrap-first-admin.ts",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "check:env-security": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/check-env-security.ts",
    "check:no-shop-route": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/check-no-shop-route.ts",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:up": "docker compose up -d",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation DISABLE_PAYLOAD_HMR=true next dev --webpack --no-server-fast-refresh",
    "dev:payload-hmr": "cross-env NODE_OPTIONS=--no-deprecation next dev --webpack --no-server-fast-refresh",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "import:cookie-media": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/import-cookie-media.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint .",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "prebuild": "pnpm run check:no-shop-route && pnpm run check:env-security",
    "predev": "pnpm run check:no-shop-route",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "seed": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed.ts",
    "seed:blog": "cross-env NODE_OPTIONS=--no-deprecation tsx scripts/seed-blog-posts.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "stripe-webhooks": "stripe listen --forward-to localhost:3000/api/payments/stripe/webhooks",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-postgres": "3.84.1",
    "@payloadcms/email-nodemailer": "3.84.1",
    "@payloadcms/email-resend": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-ecommerce": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-vercel-blob": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "1.2.11",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@stripe/react-stripe-js": "^3",
    "@stripe/stripe-js": "^4.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^8.2.0",
    "embla-carousel-auto-scroll": "^8.1.5",
    "embla-carousel-react": "^8.5.2",
    "geist": "^1.3.0",
    "graphql": "^16.8.2",
    "jsonwebtoken": "9.0.1",
    "libphonenumber-js": "^1.12.41",
    "lucide-react": "0.563.0",
    "next": "16.2.2",
    "next-themes": "0.4.6",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "qs-esm": "8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.71.1",
    "sharp": "0.34.2",
    "sonner": "^1.7.2",
    "stripe": "18.5.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@next/env": "16.2.2",
    "@next/eslint-plugin-next": "16.2.2",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "16.3.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vercel/git-hooks": "^1.0.0",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jsdom": "28.0.0",
    "lint-staged": "^15.2.2",
    "postcss": "^8.4.38",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.18",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.2",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
