# Vercel: mark secret values as Sensitive and rotate any real values that were
# previously stored as non-sensitive env vars.
PAYLOAD_SECRET=replace-with-a-long-random-string-at-least-32-chars
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/baked_with_blessings

COMPANY_NAME="Baked with Blessings"
TWITTER_CREATOR="@payloadcms"
TWITTER_SITE="https://nextjs.org/commerce"
SITE_NAME="Baked with Blessings"

PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_PHONE_COUNTRY=US

# Local first-admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME="Baked with Blessings Admin"

# Local/preview dummy customer bootstrap. The default .invalid email is reserved
# for non-deliverable test identifiers and can still be used to log in.
BOOTSTRAP_TEST_CUSTOMER_EMAIL=test.customer@baked-with-blessings.invalid
BOOTSTRAP_TEST_CUSTOMER_PASSWORD=
BOOTSTRAP_TEST_CUSTOMER_NAME="Test Customer"
BOOTSTRAP_TEST_CUSTOMER_ALLOW_PRODUCTION=false

# Twilio Verify for customer phone authentication
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Vercel Blob storage for uploaded media
BLOB_READ_WRITE_TOKEN=

# Resend for customer welcome emails and future transactional mail
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME="Baked with Blessings"

# Owner notification destinations. CONTACT_NOTIFICATION_TO falls back to ORDER_NOTIFICATION_TO.
CONTACT_NOTIFICATION_TO=
ORDER_NOTIFICATION_TO=

# Used to preview drafts
PREVIEW_SECRET=replace-with-a-long-random-preview-secret

# Stripe API keys
# These can stay as placeholders until you wire up real payments.
STRIPE_SECRET_KEY=sk_test_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOKS_SIGNING_SECRET=whsec_
